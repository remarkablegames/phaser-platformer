{
  "name": "phaser-platformer",
  "private": true,
  "version": "1.0.0-alpha",
  "type": "module",
  "scripts": {
    "build": "npm run clean && vite build",
    "bundle": "bash scripts/bundle.sh",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "lint:tsc": "tsc --project tsconfig.app.json",
    "prepare": "husky",
    "preview": "vite preview",
    "start": "vite --open"
  },
  "homepage": "https://remarkablegames.org/phaser-platformer/",
  "dependencies": {
    "phaser": "4.0.0",
    "phaser-jsx": "0.16.2"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/gtag.js": "0.0.20",
    "@types/react": "19.2.14",
    "eslint": "10.2.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vite-plugin-html": "3.2.2"
  }
}
